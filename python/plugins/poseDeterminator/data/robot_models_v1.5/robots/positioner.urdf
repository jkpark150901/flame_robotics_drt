<?xml version="1.0"?>
<robot name="positioner">
  <!-- 
       Positioner Base Link
       Fixed structure, no joints.
       Mass and inertia are omitted as it is a fixed structure.
  -->
  <link name="base_link">
    <visual>
      <!-- Adjust scale if your mesh unit is not in meters (default is 1 1 1) -->
      <!-- Adjust origin if the mesh coordinate center needs fine-tuning -->
      <origin rpy="0 0 0" xyz="0 0 0" />
      <geometry>
        <mesh filename="meshes/positioner/visual/base.dae" />
      </geometry>
      <!-- Optional: Add material color if needed. DAE usually carries its own textures. -->
    </visual>
    <collision>
      <origin rpy="0 0 0" xyz="0 0 0" />
      <geometry>
        <mesh filename="meshes/positioner/collision/base.stl" scale="0.001 0.001 0.001"/>
      </geometry>
    </collision>
  </link>

  <!-- 
       NOTE: For some physics simulation environments (like Gazebo or PyBullet),
       a base_link with no joints or inertia might still fall to the ground 
       or cause warnings.
       
       If you need to strictly fix this model to the world in a physics engine,
       uncomment the following code block:
  -->
  <!--
  <link name="world"/>
  <joint name="world_fixed_joint" type="fixed">
    <parent link="world" />
    <child link="base_link" />
    <origin rpy="0 0 0" xyz="0 0 0" />
  </joint>
  -->

  <!-- ============================================================
       f_column_z: base에서 z축으로 이동하는 prismatic joint
       m_column_z와 항상 동기화되어 동일한 z축 위치를 유지합니다.
       (동기화 로직은 kinematics 소프트웨어 레이어에서 구현 필요)
       ============================================================ -->
  <link name="f_column_z">
    <visual>
      <origin rpy="0 0 0" xyz="0.26 1.375 1.3" />
      <geometry>
        <mesh filename="meshes/positioner/visual/f_column_z.dae"/>
      </geometry>
      <material name="red_color">
        <color rgba="1.0 0.0 0.0 1.0"/>
      </material>
    </visual>
    <collision>
      <origin rpy="0 0 0" xyz="0 0 0" />
      <geometry>
        <mesh filename="meshes/positioner/collision/f_column_z.stl" scale="0.001 0.001 0.001"/>
      </geometry>
    </collision>
  </link>

  <joint name="base_to_f_column_z" type="prismatic">
    <parent link="base_link" />
    <child link="f_column_z" />
    <!-- SYNC: 이 조인트는 m_column_to_m_column_z와 동기화됩니다 (동일 z축 위치) -->
    <origin rpy="0 0 0" xyz="0 0 0" />
    <axis xyz="0 0 1" />
    <limit effort="1000.0" lower="0.0" upper="0.85" velocity="1.0" />
  </joint>

  <!-- ============================================================
       m_column: 수동으로 조작되는 prismatic joint (x축 이동)
       Kinematics 해석 시 이 조인트의 구동값은 사용자가 입력한 값을
       계속 유지해야 합니다 (수동 조작 조인트).
       Movement range: 0 ~ 8500 mm (0.0 ~ 8.5 m)
       ============================================================ -->
  <link name="m_column">
    <visual>
      <origin rpy="0 0 0" xyz="0 0 0" />
      <geometry>
        <mesh filename="meshes/positioner/visual/m_column.dae"/>
      </geometry>
      <material name="green_color">
        <color rgba="0.0 1.0 0.0 1.0"/>
      </material>
    </visual>
    <collision>
      <origin rpy="0 0 0" xyz="0 0 0" />
      <geometry>
        <mesh filename="meshes/positioner/collision/m_column.stl" scale="0.001 0.001 0.001"/>
      </geometry>
    </collision>
  </link>

  <!-- MANUAL JOINT: 수동 조작 조인트 - kinematics 해석 시 사용자 입력값 유지 -->
  <joint name="base_to_m_column" type="prismatic">
    <parent link="base_link" />
    <child link="m_column" />
    <!-- 특정 옵셋만큼 떨어진 위치 (필요시 수정) -->
    <origin rpy="0 0 0" xyz="8.0 1.377 0.328" />
    <axis xyz="1 0 0" />
    <limit effort="1000.0" lower="-4.7" upper="0.0" velocity="1.0" />
  </joint>

  <!-- ============================================================
       m_column_z: m_column에서 z축으로 이동하는 prismatic joint
       f_column_z와 항상 동기화되어 동일한 z축 위치를 유지합니다.
       (동기화 로직은 kinematics 소프트웨어 레이어에서 구현 필요)
       ============================================================ -->
  <link name="m_column_z">
    <visual>
      <origin rpy="0 0 0" xyz="0 0 0.885" />
      <geometry>
        <mesh filename="meshes/positioner/visual/m_column_z.dae"/>
      </geometry>
      <material name="red_color">
        <color rgba="1.0 0.0 0.0 1.0"/>
      </material>
    </visual>
    <collision>
      <origin rpy="0 0 0" xyz="0 0 0" />
      <geometry>
        <mesh filename="meshes/positioner/collision/m_column_z.stl" scale="0.001 0.001 0.001"/>
      </geometry>
    </collision>
  </link>

  <!-- SYNC: 이 조인트는 base_to_f_column_z와 동기화됩니다 (동일 z축 위치) -->
  <joint name="m_column_to_m_column_z" type="prismatic">
    <parent link="m_column" />
    <child link="m_column_z" />
    <origin rpy="0 0 0" xyz="0 0 0" />
    <axis xyz="0 0 1" />
    <limit effort="1000.0" lower="0.0" upper="0.85" velocity="1.0" />
    <mimic joint="base_to_f_column_z" multiplier="1.0" offset="0.0" />
  </joint>
  <!-- ============================================================
       m_column_passive_r: m_column_z 하위의 revolute joint
       수동으로 조작하는 조인트로 사용자가 입력하는 값에만 대응합니다.
       ============================================================ -->
  <link name="m_column_passive_r">
    <visual>
      <origin rpy="0 0 0" xyz="0 0 0" />
      <geometry>
        <mesh filename="meshes/positioner/visual/m_column_passive_r.dae"/>
      </geometry>
    </visual>
    <collision>
      <origin rpy="0 0 0" xyz="0.247 0 -0.885" />
      <geometry>
        <mesh filename="meshes/positioner/collision/m_column_passive_r.stl" scale="0.001 0.001 0.001"/>
      </geometry>
    </collision>
  </link>

  <!-- MANUAL JOINT: 수동 조작 조인트 - kinematics 해석 시 사용자 입력값 대응 -->
  <joint name="m_column_z_to_m_column_passive_r" type="revolute">
    <parent link="m_column_z" />
    <child link="m_column_passive_r" />
    <origin rpy="0 0 0" xyz="-0.247 0 0.885" />
    <axis xyz="1 0 0" /> <!-- 회전축은 필요시 수정 -->
    <limit effort="1000.0" lower="-3.14159" upper="3.14159" velocity="1.0" />
  </joint>
  <!-- ============================================================
       f_column_r: f_column_z 하위의 revolute joint
       ============================================================ -->
  <link name="f_column_r">
    <visual>
      <origin rpy="0 0 0" xyz="0 0 0" />
      <geometry>
        <mesh filename="meshes/positioner/visual/f_column_r.dae"/>
      </geometry>
      <material name="purple_color">
        <color rgba="0.5 0.0 0.5 1.0"/>
      </material>
    </visual>
    <collision>
      <origin rpy="0 0 0" xyz="0 0 0" />
      <geometry>
        <mesh filename="meshes/positioner/collision/f_column_r.stl" scale="0.001 0.001 0.001"/>
      </geometry>
    </collision>
  </link>

  <joint name="f_column_z_to_f_column_r" type="revolute">
    <parent link="f_column_z" />
    <child link="f_column_r" />
    <origin rpy="0 0 0" xyz="0.48 1.37 1.3" />
    <axis xyz="1 0 0" />
    <limit effort="1000.0" lower="-3.14159" upper="3.14159" velocity="1.0" />
  </joint>

  <!-- ============================================================
       f_column_passive_clamp: f_column_r 하위의 prismatic joint
       ============================================================ -->
  <link name="f_column_passive_clamp">
    <visual>
      <origin rpy="0 0 0" xyz="0 0 0" />
      <geometry>
        <mesh filename="meshes/positioner/visual/f_column_passive_clamp.dae"/>
      </geometry>
    </visual>
    <collision>
      <origin rpy="0 0 0" xyz="0 0 0" />
      <geometry>
        <mesh filename="meshes/positioner/collision/f_column_passive_clamp.stl" scale="0.001 0.001 0.001"/>
      </geometry>
    </collision>
  </link>

  <joint name="f_column_r_to_f_column_passive_clamp" type="prismatic">
    <parent link="f_column_r" />
    <child link="f_column_passive_clamp" />
    <origin rpy="0 0 0" xyz="0.427 0.9 0.0" />
    <axis xyz="0 1 0" />
    <limit effort="1000.0" lower="-0.9" upper="0.0" velocity="1.0" />
  </joint>

</robot>